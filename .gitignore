# Python
__pycache__/
*.pyc

# Virtual Environment
venv/
tf_env/

# Data files - These can be large and should not be in version control.
# The raw video dataset (data/) contains gigabyte-size files; GitHub
# rejects anything over 100MB, so it must never be committed.
data/
*.csv
*.mp4
*.mov
*.MOV
*.m4v

# Run logs and scratch files
*.log

# Model and Scaler files
*.keras
*.joblib
*.task
# ...except the deployed inference artifacts, small enough to version and
# needed to run test.py on another machine without retraining.
!blink_model_15fps.keras
!blink_model_30fps.keras
!scaler_15fps.joblib
!scaler_30fps.joblib
!face_landmarker.task

# Output files
*.png